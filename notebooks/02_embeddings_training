# --- Morphological Tokenization for RusVectōrēs ---
morph = pymorphy3.MorphAnalyzer()

def tokenize_with_pos(text: str):
    tokens = [t.text for t in razdel.tokenize(text)]
    result = []
    for t in tokens:
        if re.fullmatch(r"[a-zа-яё]+", t):
            p = morph.parse(t)[0]
            lemma = p.normal_form
            pos = p.tag.POS
            if pos:
                result.append(f"{lemma}_{pos}")
        else:
            result.append(t)
    return result

