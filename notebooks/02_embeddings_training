# --- Load preprocessed data ---
train_df = pd.read_csv("train.csv")
val_df = pd.read_csv("val.csv")
test_df = pd.read_csv("test.csv")

# --- Tokenization ---
def simple_tokenize(text: str):
    text = text.lower()
    text = re.sub(r"[^а-яa-z0-9ё ]+", " ", text)
    return text.split()

def build_corpus(texts: pd.Series):
    return [simple_tokenize(t) for t in texts]

train_corpus = build_corpus(train_df["text"])
val_corpus = build_corpus(val_df["text"])
test_corpus = build_corpus(test_df["text"])

# --- Train Word2Vec ---
def train_word2vec(corpus, vector_size=100, window=5, min_count=5, workers=4, sg=1, epochs=10, seed=42):
    model = Word2Vec(
        sentences=corpus,
        vector_size=vector_size,
        window=window,
        min_count=min_count,
        workers=workers,
        sg=sg,
        seed=seed,
    )
    model.train(corpus, total_examples=len(corpus), epochs=epochs)
    return model

w2v_model = train_word2vec(train_corpus)

# --- Intrinsic Evaluation ---
def inspect_embeddings(model):
    words = ["россия", "москва", "футбол", "экономика"]
    for w in words:
        if w in model.wv:
            print(f"\nSimilar words for '{w}':")
            for s, score in model.wv.most_similar(w, topn=5):
                print(s, score)
    group = [w for w in words if w in model.wv]
    if len(group) >= 3:
        print("\nOdd one out:", model.wv.doesnt_match(group))

inspect_embeddings(w2v_model)

