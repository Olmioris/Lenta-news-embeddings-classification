# Создание DataFrame

def load_lenta_df(path: str, limit: int = 100_000) -> pd.DataFrame:
    records = load_lenta(path)
    data = []
    for i, record in enumerate(records):
        if i >= limit:
            break
        data.append({
            "title": record.title,
            "text": record.text,
            "topic": record.topic,
        })
    df = pd.DataFrame(data)
    df = df.dropna(subset=["text", "topic"])
    return df

df = load_lenta_df(gz_dst)
df.head()

#Удаление редких классов

topic_counts = df["topic"].value_counts()
df = df[df["topic"].isin(topic_counts[topic_counts >= 2].index)]
df = df.reset_index(drop=True)

# Разбиение на train/val/test

def split_dataset(df, test_size=0.2, val_size=0.2, random_state=42):
    train_val, test = train_test_split(
        df, test_size=test_size, stratify=df["topic"], random_state=random_state
    )
    rel_val = val_size / (1 - test_size)
    train, val = train_test_split(
        train_val, test_size=rel_val, stratify=train_val["topic"], random_state=random_state
    )
    return train, val, test

train_df, val_df, test_df = split_dataset(df)

# Сохранение выборок

train_df.to_csv("train.csv", index=False)
val_df.to_csv("val.csv", index=False)
test_df.to_csv("test.csv", index=False)
