# Lenta News — Data Preparation
# This notebook loads the Lenta.ru dataset, cleans it, removes rare classes and splits it into train/validation/test sets with stratification.

# --- Imports ---
import os
import re
import pandas as pd
import numpy as np

from corus import load_lenta
from sklearn.model_selection import train_test_split
import kagglehub

RANDOM_STATE = 42
np.random.seed(RANDOM_STATE)

# --- Download dataset via KaggleHub ---
dataset_path = kagglehub.dataset_download(
    "yutkin/corpus-of-russian-news-articles-from-lenta"
)

csv_src = os.path.join(dataset_path, "lenta-ru-news.csv")
csv_dst = "/content/lenta-ru-news.csv"
gz_dst = "/content/lenta-ru-news.csv.gz"

!cp "{csv_src}" "{csv_dst}"
!gzip -kf "{csv_dst}"

print("Dataset downloaded and copied.")

# --- Load dataset into DataFrame ---
def load_lenta_df(path: str, limit: int = 100_000) -> pd.DataFrame:
    records = load_lenta(path)
    data = []

    for i, record in enumerate(records):
        if i >= limit:
            break
        data.append({
            "title": record.title,
            "text": record.text,
            "topic": record.topic,
        })

    df = pd.DataFrame(data)
    df = df.dropna(subset=["text", "topic"])
    return df

df = load_lenta_df(gz_dst)
df.head()

print("Loaded:", len(df), "records")

# --- Remove rare classes (<2 samples) ---
topic_counts = df["topic"].value_counts()
df = df[df["topic"].isin(topic_counts[topic_counts >= 2].index)]
df = df.reset_index(drop=True)

print("Remaining classes:", df["topic"].nunique())

# --- Stratified split: 60/20/20 ---
def split_dataset(
    df: pd.DataFrame,
    test_size: float = 0.2,
    val_size: float = 0.2,
    random_state: int = RANDOM_STATE,
):
    train_val, test = train_test_split(
        df,
        test_size=test_size,
        stratify=df["topic"],
        random_state=random_state,
    )

    rel_val = val_size / (1 - test_size)

    train, val = train_test_split(
        train_val,
        test_size=rel_val,
        stratify=train_val["topic"],
        random_state=random_state,
    )

    return train, val, test

train_df, val_df, test_df = split_dataset(df)

print("Train:", len(train_df))
print("Val:", len(val_df))
print("Test:", len(test_df))

# --- Save splits ---
train_df.to_csv("train.csv", index=False)
val_df.to_csv("val.csv", index=False)
test_df.to_csv("test.csv", index=False)

print("Saved train.csv, val.csv, test.csv")

# --- Class distribution visualization ---
import matplotlib.pyplot as plt

def plot_class_distribution(df, title):
    plt.figure(figsize=(12, 5))
    df["topic"].value_counts().plot(kind="bar")
    plt.title(title)
    plt.show()

plot_class_distribution(df, "Full Dataset Class Distribution")
plot_class_distribution(train_df, "Train Distribution")
plot_class_distribution(val_df, "Validation Distribution")
plot_class_distribution(test_df, "Test Distribution")
