# --- Train Logistic Regression on TF‑IDF weighted embeddings ---
def train_eval_logreg(X_train, y_train, X_val, y_val):
    clf = LogisticRegression(max_iter=1000, n_jobs=-1, random_state=42)
    clf.fit(X_train, y_train)
